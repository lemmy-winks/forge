# --- required ---
POSTGRES_PASSWORD=change-me-to-something-long
SESSION_SECRET=change-me-to-a-long-random-string

# The entire allowlist: comma-separated email:Name pairs. First user is admin.
ALLOWED_USERS=you@example.com:You,partner@example.com:Partner

# --- ingress ---
# Public URL once behind your reverse proxy. Localhost for first run.
BASE_URL=http://localhost:33524
FORGE_PORT=33524

# --- Google sign-in (optional at first) ---
# Create an OAuth client (Web) in Google Cloud Console; authorized redirect URI:
#   {BASE_URL}/auth/callback
# While these are empty, dev sign-in buttons are shown instead (LAN use only).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Force dev sign-in even with Google configured (never expose this publicly)
DEV_AUTH=false

# --- the coach (Phase 3) ---
# From console.anthropic.com -> API keys. Without it, chat shows a clear "not
# configured" message and the weekly review scheduler stays idle.
ANTHROPIC_API_KEY=
COACH_MODEL=claude-sonnet-5
# Weekly review runs Sunday from 20:00 in this timezone, once per week per user.
COACH_TZ=Europe/London
